{
  "name": "agent-relay-desktop",
  "version": "0.2.0",
  "description": "Local agent collaboration scheduler with declared read/write boundaries",
  "author": "Synapse Relay Maintainers",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "pack:dir": "electron-builder --dir",
    "pack:portable": "electron-builder --win portable",
    "tauri": "tauri"
  },
  "build": {
    "appId": "com.synapse.agentrelay",
    "productName": "Agent Relay",
    "electronVersion": "42.4.0",
    "directories": {
      "output": "../dist-desktop"
    },
    "files": [
      "main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend"
      },
      {
        "from": "../\u5185\u9601-ai-app/dist",
        "to": "\u5185\u9601-ai-app/dist"
      },
      {
        "from": "../launch.py",
        "to": "launch.py"
      },
      {
        "from": "../requirements.txt",
        "to": "requirements.txt"
      },
      {
        "from": "../.env.example",
        "to": ".env.example"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.8.1"
  }
}
